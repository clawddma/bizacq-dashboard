# --- BizScout (requires authenticated session) ---
# Provide EITHER email+password OR a pre-extracted session cookie.
BIZSCOUT_EMAIL=
BIZSCOUT_PASSWORD=
BIZSCOUT_COOKIE=

# --- GitHub auto-commit for the daily routine ---
# Personal access token with `repo` scope. Used to push data/deals.json updates.
GITHUB_TOKEN=

LOG_LEVEL=INFO
